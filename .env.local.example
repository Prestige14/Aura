# ============================================================
# AURA: The Autonomous Web3 Concierge - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# --- NETWORK CONFIGURATION ---
# Supported: "arbitrum-sepolia" or "base-sepolia"
NEXT_PUBLIC_NETWORK=arbitrum-sepolia

# Arbitrum Sepolia RPC URL (get from Alchemy, Infura, or Ankr)
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Base Sepolia RPC URL
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# --- DEVELOPER WALLET (SERVER-SIDE ONLY — NEVER EXPOSE) ---
# Private key of a funded developer wallet (for faucet functionality)
# This wallet must hold testnet USDC on Arbitrum/Base Sepolia
DEVELOPER_PRIVATE_KEY=0x...your_private_key_here...

# --- USDC CONTRACT ADDRESSES ---
# Arbitrum Sepolia USDC (Circle's testnet USDC)
NEXT_PUBLIC_USDC_ADDRESS_ARBITRUM_SEPOLIA=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Base Sepolia USDC
NEXT_PUBLIC_USDC_ADDRESS_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- 1SHOT API CONFIGURATION ---
# Base URL for 1Shot Permissionless Relayer (no API key needed for public relayer)
NEXT_PUBLIC_ONESHOT_RELAYER_URL=https://relayer.1shotapi.com

# DelegationManager contract address (1Shot's deployed contract on Arbitrum Sepolia)
NEXT_PUBLIC_DELEGATION_MANAGER_ADDRESS=0x2a6b3e4e48a5aA04E6A0E81B49e7B34FEa3D0BC

# --- VENICE AI CONFIGURATION ---
# Get your API key from: https://venice.ai/dashboard/api-keys
VENICE_API_KEY=your_venice_api_key_here
NEXT_PUBLIC_VENICE_API_BASE=https://api.venice.ai/api/v1

# Venice AI models to use
NEXT_PUBLIC_VENICE_TEXT_MODEL=llama-3.3-70b
NEXT_PUBLIC_VENICE_IMAGE_MODEL=fluently-xl

# Venice AI "receiver" wallet address (for x402 micro-payments)
# This simulates paying Venice AI for AI inference
NEXT_PUBLIC_VENICE_RECEIVER_WALLET=0x4F96Fe3b7A6Cf9725f59d353F723c1bDb64CA6Aa

# --- METAMASK SMART ACCOUNTS KIT ---
# The address of the smart account implementation (Gator/Hybrid Delegator)
# MetaMask's official Hybrid Delegator on Arbitrum Sepolia
NEXT_PUBLIC_SMART_ACCOUNT_IMPLEMENTATION=0xDEc9f5e91bDf48ed8e5A9eA8Ab37B01d49c57cEa

# --- AURA AGENT CONFIGURATION ---
# Micro-payment amounts (in USDC, 6 decimals)
# 1 USDC = 1_000_000 (6 decimals for USDC)
NEXT_PUBLIC_WRITER_AGENT_BUDGET=1000000
NEXT_PUBLIC_DESIGNER_AGENT_BUDGET=1000000
NEXT_PUBLIC_PAYMENT_AMOUNT=100000

# --- SESSION CONFIGURATION ---
# How long ERC-7715 sessions are valid (in seconds)
NEXT_PUBLIC_SESSION_DURATION=86400

# --- FAUCET CONFIGURATION ---
# How much testnet USDC to send to new users (6 decimals)
NEXT_PUBLIC_FAUCET_AMOUNT=5000000
